# DB / Redis (docker-compose 기본값)
DATABASE_URL=postgresql://kabu:kabu@localhost:5432/mock_kabu
REDIS_URL=redis://localhost:6379

# api
API_PORT=4000
JWT_SECRET=local-dev-secret-change-me

# 락 전략: optimistic | pessimistic | distributed
LOCK_STRATEGY=pessimistic

# web
NEXT_PUBLIC_API_URL=http://localhost:4000

# bots
BOT_API_URL=http://localhost:4000
# Dedicated liquidity reserve bootstrap (clean bot16..bot20 generation).
# Locally these may stay unset: both API and bots fall back to JWT_SECRET.
# In any shared/deployed environment set the same, separate strong token in
# both processes; it is required by POST /internal/liquidity/ensure.
# LIQUIDITY_BOOTSTRAP_TOKEN=replace-with-a-separate-strong-local-secret
# LIQUIDITY_BOT_PASSWORD=botpassword

# 실전 리플레이 (선택 사항)
# 비워 두면 외부 시세 요청을 전혀 하지 않습니다. AAPL 내장 fixture만 사용할 수 있습니다.
# ALPHA_VANTAGE_API_KEY=
# 사용자가 권한을 가진 <dataset-id>.csv(aapl-us.csv 등)가 있는 절대 경로입니다.
# REPLAY_HISTORICAL_CSV_DIR=
