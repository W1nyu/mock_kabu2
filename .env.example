# mock_kabu2 전용 런타임 (원본 mock_kabu와 공유하지 않음)
COMPOSE_PROJECT_NAME=mock-kabu2
DATABASE_URL=postgresql://kabu2:kabu2@localhost:55432/mock_kabu2
REDIS_URL=redis://localhost:56379

# api
API_PORT=4100
WEB_ORIGIN=http://localhost:3100,http://127.0.0.1:3100
JWT_SECRET=mock-kabu2-local-dev-secret

# 락 전략: optimistic | pessimistic | distributed
LOCK_STRATEGY=pessimistic

# web
NEXT_PUBLIC_API_URL=http://localhost:4100

# bots
BOT_API_URL=http://localhost:4100
# Dedicated liquidity reserve bootstrap (clean bot16..bot20 generation).
# API와 bots가 같은 전용 토큰을 사용합니다.
# POST /internal/liquidity/ensure에 필요하므로 두 프로세스에서 같아야 합니다.
LIQUIDITY_BOOTSTRAP_TOKEN=mock-kabu2-local-liquidity-token
# LIQUIDITY_BOT_PASSWORD=botpassword

# 실전 리플레이는 항상 내장 고정 일봉을 사용하며 외부 시세를 요청하지 않습니다.
# 아래 키는 향후 고정 데이터 갱신 작업을 준비할 때만 로컬 .env에 보관합니다. 커밋하거나 NEXT_PUBLIC_ 변수로 노출하지 마세요.
# ALPHA_VANTAGE_API_KEY=
